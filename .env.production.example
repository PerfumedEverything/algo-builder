# Supabase (Kong API gateway on the same server)
NEXT_PUBLIC_SUPABASE_URL=http://YOUR_SERVER_IP:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Docker internal hostname)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@supabase-db:5432/postgres

# Redis (Docker internal hostname)
REDIS_URL=redis://redis:6379

# AI Provider
AI_PROVIDER=deepseek
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# T-Invest
TINKOFF_INVEST_TOKEN=
TINKOFF_SANDBOX=true

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://YOUR_SERVER_IP

# Signal checker cron
CRON_SECRET=your-cron-secret
