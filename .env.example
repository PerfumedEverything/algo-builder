# ===========================
# Supabase
# ===========================
# Supabase project URL (public, used client-side)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
# Supabase anon key (public, used client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Supabase service role key (server-only, full DB access)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================
# Database
# ===========================
# PostgreSQL connection string (used by Prisma)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# ===========================
# Redis
# ===========================
# Redis connection URL (must include password in production: redis://:password@host:6379)
REDIS_URL=redis://localhost:6379
# Redis password (used in docker-compose for requirepass)
REDIS_PASSWORD=your-redis-password

# ===========================
# AI Provider
# ===========================
# AI provider: "claude" or "deepseek"
AI_PROVIDER=deepseek
# Anthropic API key (required if AI_PROVIDER=claude)
ANTHROPIC_API_KEY=
# DeepSeek API key (required if AI_PROVIDER=deepseek)
DEEPSEEK_API_KEY=
# DeepSeek API base URL
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===========================
# T-Invest (MOEX broker)
# ===========================
# User-level T-Invest API token (per-user, stored in settings)
TINKOFF_INVEST_TOKEN=
# System-level T-Invest token (for price-stream-worker, shared across all users)
TINKOFF_SYSTEM_TOKEN=
# Use T-Invest sandbox mode ("true" or "false")
TINKOFF_SANDBOX=true

# ===========================
# Bybit (crypto broker)
# ===========================
# Bybit API key (for bybit-stream-worker)
BYBIT_API_KEY=
# Bybit API secret
BYBIT_API_SECRET=
# Use Bybit testnet ("true" for testnet, "false" for mainnet production)
BYBIT_TESTNET=true

# ===========================
# Telegram
# ===========================
# Telegram bot token (for notifications and bot commands)
TELEGRAM_BOT_TOKEN=
# Telegram admin chat ID (for smoke monitor alerts)
TELEGRAM_ADMIN_CHAT_ID=
# Smoke monitor chat ID (falls back to TELEGRAM_ADMIN_CHAT_ID)
SMOKE_CHAT_ID=
# MAX bot token (optional, second bot)
MAX_BOT_TOKEN=

# ===========================
# Cron / Internal API
# ===========================
# Secret for authenticating cron/internal API calls (signal checks, smoke probes)
CRON_SECRET=your-cron-secret

# ===========================
# App
# ===========================
# Public app URL (used for internal API calls and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
